{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "1.0",
  "icons": {
    "16": "icons/formulane16.png",
    "32": "icons/formulane32.png",
    "48": "icons/formulane48.png",
    "128": "icons/formulane128.png"
  },
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://api.openf1.org/*"],
  "action": { "default_popup": "src/popup/popup.html" },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": { "service_worker": "src/background.js" }
}